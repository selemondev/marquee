{
  "name": "@selemondev/vue3-marquee",
  "version": "1.1.0",
  "private": false,
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json",
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build:package": "pnpm generate:css && vp pack",
    "dev:build": "vp pack --watch ./src/index.ts",
    "dev": "tsx ./src/index.ts",
    "play:dev": "vp dev",
    "biome": "biome check --write",
    "test": "vp test",
    "coverage": "vp test run --coverage",
    "generate:release": "pnpx changelogen@latest --release && git push --follow-tags",
    "generate:major:release": "pnpx changelogen@latest --major --release && git push --follow-tags",
    "generate:minor:release": "pnpx changelogen@latest --minor && git push --follow-tags",
    "generate:patch:release": "pnpx changelogen@latest --patch && git push --follow-tags",
    "bump:version": "pnpx changelogen@latest --bump",
    "package:beta": "pnpm build:package && pnpm publish --tag beta",
    "package": "pnpm build:package && pnpm publish --access=public",
    "generate:css": "pnpx @tailwindcss/cli -i ./src/assets/css/tailwind.css -o ./src/assets/css/output.css --minify"
  },
  "dependencies": {
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tsconfig/node18": "^18.2.6",
    "@tsdown/css": "^0.21.9",
    "@vue/tsconfig": "^0.7.0",
    "npm-run-all2": "^8.0.4",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "unplugin-vue": "^7.1.0",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vue": "^3.5.26",
    "vue-tsc": "^3.1.8"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "packageManager": "pnpm@10.27.0",
  "inlinedDependencies": {
    "clsx": "2.1.1",
    "tailwind-merge": "2.6.1"
  }
}
