{
  "name": "@selemondev-marquee/root",
  "version": "0.1.0",
  "description": "A Beautiful Marquee component for Vue",
  "keywords": [
    "marquee",
    "tailwindcss",
    "typescript",
    "vue",
    "vue3"
  ],
  "bugs": {
    "url": "https://github.com/selemondev/marquee/issues"
  },
  "license": "MIT",
  "author": "Selemondev",
  "repository": {
    "type": "git",
    "url": "https://github.com/selemondev/marquee"
  },
  "type": "module",
  "scripts": {
    "generate:major:release": "pnpx changelogen@latest --major && git push --follow-tags",
    "generate:minor:release": "pnpx changelogen@latest --minor && git push --follow-tags",
    "generate:patch:release": "pnpx changelogen@latest --patch && git push --follow-tags",
    "prepare": "vp config",
    "lint": "vp lint",
    "build": "pnpm --filter @selemondev/vue3-marquee build:package && pnpm --filter docs build:docs"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@10.33.0"
}
