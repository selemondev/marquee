{
  "name": "@selemondev-marquee/root",
  "version": "1.1.0",
  "private": "true",
  "description": "A Beautiful Marquee component for Vue",
  "keywords": [
    "marquee",
    "tailwindcss",
    "typescript",
    "vue",
    "vue3"
  ],
  "bugs": {
    "url": "https://github.com/selemondev/marquee/issues"
  },
  "license": "MIT",
  "author": "Selemondev",
  "repository": {
    "type": "git",
    "url": "https://github.com/selemondev/marquee"
  },
  "type": "module",
  "scripts": {
    "generate:patch:release": "node scripts/release.mjs",
    "generate:minor:release": "node scripts/release.mjs --minor",
    "generate:major:release": "node scripts/release.mjs --major",
    "prepare": "vp config",
    "lint": "vp lint",
    "build": "pnpm --filter @selemondev/vue3-marquee build:package && pnpm --filter docs build:docs",
    "build:astro:docs": "pnpm --filter docs build:docs",
    "build:marquee:package": "pnpm --filter @selemondev/vue3-marquee build:package"
  },
  "dependencies": {
    "@types/node": "^25.6.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@10.27.0"
}
